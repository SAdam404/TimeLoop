<?xml version="1.0" encoding="utf-8"?>
<ui>

  <!-- Root fills the entire Canvas -->
  <panel id="Root" stretch="true" background="#0F0F1EFF">

    <!-- ── Header Bar ──────────────────────────────────── -->
            <panel id="HeaderBar" anchor="top-center" widthPercent="1" height="180" y="0"
           background="#1A1A30FF">
      <text id="AppTitle"
            anchor="middle-center"
            value="ActivityTimer"
            widthPercent="0.95"
            height="150"
            align="middle-center"
              fontSize="120"
            color="#E2B96FFF"/>
    </panel>

    <!-- ── Preset Scroll List (fills space between header and bottom bar) ── -->
    <scrollview id="PresetList"
                stretch="true"
                top="188"
                bottom="164"
                left="12"
                right="12"
                spacing="18"/>

    <!-- ── Empty State (shown when no presets exist) ─────── -->
    <text id="EmptyHint"
          anchor="middle-center"
          widthPercent="0.88"
          height="300"
          value="No timers yet.&#xA;Tap + New Timer to create one."
          fontSize="80"
          color="#6868A0FF"/>

    <!-- ── Bottom Action Bar ──────────────────────────────── -->
    <panel id="BottomBar" anchor="bottom-center" widthPercent="1" height="164" y="0"
           background="#1A1A30FF">

      <button id="AddPresetBtn"
              anchor="middle-right"
              x="-16"
              width="560"
              height="120"
              text="New Timer"
              buttonFontSize="64"
              icon="TimeLoop/Icons/ic_add"
              iconSize="48"
              iconAlign="left"
              buttonColor="#3B6FF5FF"
              textColor="#FFFFFFFF"
              event="preset.add"/>

    </panel>

  </panel>

</ui>
