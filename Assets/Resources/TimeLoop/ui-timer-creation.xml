<?xml version="1.0" encoding="utf-8"?>
<ui>

  <panel id="Root" stretch="true" background="#101321FF">

        <panel id="HeaderBar" anchor="top-center" widthPercent="1" height="170" background="#1A1A30FF">
      <text id="CreationTitle"
            anchor="middle-center"
            value="Create Timer"
            widthPercent="0.95"
            height="120"
            align="middle-center"
              fontSize="64"
            color="#E2B96FFF"/>
    </panel>

    <scrollview id="CreationScroll"
                stretch="true"
          top="178"
          bottom="126"
                left="8"
                right="8"
                spacing="12">

      <panel id="PresetSection"
       height="320"
       preferredHeight="320"
             background="#1D2238FF">
        <text id="PresetSectionTitle"
              anchor="top-left"
              x="16"
              y="-22"
          width="420"
              height="42"
              value="Preset Data"
              fontSize="68"
              align="middle-left"
              color="#F4F6FFFF"/>

          <text id="PresetTotalDurationLabel"
            anchor="top-right"
            x="-16"
            y="-22"
            width="220"
            height="42"
            value="00:00"
            fontSize="44"
            align="middle-right"
            color="#C7D1F7FF"/>

        <text id="NameLabel"
              anchor="top-left"
              x="16"
              y="-72"
              width="520"
              height="64"
              value="Timer Name"
              fontSize="44"
              align="middle-left"
              color="#C7D1F7FF"/>

        <inputfield id="PresetNameInput"
              anchor="top-center"
              x="0"
                  y="-196"
              widthPercent="0.95"
                height="96"
                    placeholder="Morning Focus"
              inputType="name"
              maxLength="24"
                    background="#262C45FF"
                    color="#FFFFFFFF"
                fontSize="56"/>
      </panel>

      <panel id="LoopSection"
             height="872"
             preferredHeight="872"
           background="#1D2238FF">

        <text id="LoopSectionTitle"
              anchor="top-left"
              x="16"
              y="-22"
              width="420"
              height="42"
              value="Loops"
              fontSize="68"
              align="middle-left"
              color="#F4F6FFFF"/>

          <text id="LoopTotalDurationLabel"
            anchor="top-right"
            x="-16"
            y="-22"
            width="220"
            height="42"
            value="00:00"
            fontSize="44"
            align="middle-right"
            color="#C7D1F7FF"/>

        <row id="LoopHeaderRow"
             anchor="top-center"
             x="0"
             y="-76"
             widthPercent="1"
             height="96"
             spacing="8"
             background="transparent">
           <text id="LoopNameLabel" preferredWidth="320" preferredHeight="84" value="Loop 1" fontSize="56" align="middle-left" color="#DEE5FFFF"/>
           <text id="RepeatLabel" preferredWidth="300" preferredHeight="84" value="Repeat" fontSize="48" align="middle-right" color="#8D98C4FF"/>
        </row>

        <panel id="LoopDragHandle"
               anchor="top-right"
               x="-10"
               y="-76"
               width="92"
               height="92"
               background="#2D3557FF">
          <separator id="LoopDragLine1" anchor="top-center" y="-24" width="36" thickness="4" color="#93A8E8FF"/>
          <separator id="LoopDragLine2" anchor="top-center" y="-46" width="36" thickness="4" color="#93A8E8FF"/>
          <separator id="LoopDragLine3" anchor="top-center" y="-68" width="36" thickness="4" color="#93A8E8FF"/>
        </panel>

        <row id="LoopRepeatControlsRow"
             anchor="top-center"
             x="0"
             y="-190"
             widthPercent="1"
             height="104"
             spacing="10"
             background="#252C48FF">
          <button id="LoopRepeatMinus" flex="1" preferredHeight="88" text="-" buttonFontSize="64" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
          <inputfield id="LoopRepeatInput" flex="2" preferredHeight="88" value="1" placeholder="1" inputType="integer" maxLength="2" background="#262C45FF" color="#FFFFFFFF" fontSize="56"/>
          <button id="LoopRepeatPlus" flex="1" preferredHeight="88" text="+" buttonFontSize="64" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
        </row>

        <row id="EntryRowHeader"
             anchor="top-center"
             x="0"
             y="-360"
             widthPercent="1"
             height="60"
             spacing="8"
             background="transparent"
             active="false">
           <text id="EntryNameHead" flex="1" preferredHeight="54" value="Name" fontSize="44" align="middle-left" color="#8D98C4FF"/>
        </row>

        <row id="EntryRow1"
             anchor="top-center"
             x="0"
             y="-360"
             widthPercent="1"
             height="110"
             spacing="8"
             background="#252C48FF">
            <inputfield id="Entry1Name" flex="1" preferredHeight="92" value="Warmup" placeholder="Entry name" inputType="standard" maxLength="40" background="#262C45FF" color="#FFFFFFFF" fontSize="52"/>
            <panel id="Entry1DragHandle" preferredWidth="92" preferredHeight="92" background="#2D3557FF">
              <separator id="Entry1DragLine1" anchor="top-center" y="-24" width="36" thickness="4" color="#93A8E8FF"/>
              <separator id="Entry1DragLine2" anchor="top-center" y="-46" width="36" thickness="4" color="#93A8E8FF"/>
              <separator id="Entry1DragLine3" anchor="top-center" y="-68" width="36" thickness="4" color="#93A8E8FF"/>
            </panel>
        </row>

        <row id="EntryDurationHeader"
             anchor="top-center"
             x="0"
             y="-482"
             widthPercent="1"
             height="60"
             spacing="8"
             background="transparent"
             active="false">
           <text id="EntryDurationHead" flex="1" preferredHeight="54" value="Duration (MM:SS)" fontSize="44" align="middle-left" color="#8D98C4FF"/>
        </row>

        <row id="EntryDurationRow"
             anchor="top-center"
             x="0"
             y="-482"
             widthPercent="1"
             height="110"
             spacing="8"
             background="#252C48FF">
          <button id="Entry1DurationMinus" flex="1" preferredHeight="92" text="-" buttonFontSize="56" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
           <inputfield id="Entry1Duration" flex="2" preferredHeight="92" value="05:00" placeholder="00:30" inputType="duration" maxLength="5" background="#262C45FF" color="#FFFFFFFF" fontSize="52"/>
          <button id="Entry1DurationPlus" flex="1" preferredHeight="92" text="+" buttonFontSize="56" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
        </row>

        <row id="EntryControlsRow"
             anchor="top-center"
             x="0"
             y="-604"
             widthPercent="1"
             height="110"
             spacing="12"
             background="#252C48FF">
          <button id="Entry1Color" flex="1" preferredHeight="92" text="Color" buttonFontSize="42" buttonColor="#3B6FF5FF" textColor="#FFFFFFFF"/>
          <button id="Entry1Dup" flex="1" preferredHeight="92" text="Duplicate" buttonFontSize="42" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
          <button id="Entry1Delete" flex="1" preferredHeight="92" text="Delete" buttonFontSize="42" buttonColor="#7A2A32FF" textColor="#FFFFFFFF"/>
        </row>

        <row id="AddButtonsRow"
             anchor="top-center"
             x="0"
             y="-758"
             widthPercent="1"
             height="110"
             spacing="12"
             background="transparent">
          <button id="AddEntryBtn"
                  flex="1"
                  preferredHeight="96"
                  text="+ Add Entry"
                  buttonFontSize="42"
                  buttonColor="#38405EFF"
                  textColor="#FFFFFFFF"/>
        </row>

      </panel>

      <panel id="AddLoopPanel" height="110" preferredHeight="110" background="transparent">
        <button id="AddLoopBtn"
                anchor="middle-center"
                widthPercent="1"
                height="96"
                text="+ Add Loop"
                buttonFontSize="42"
                buttonColor="#38405EFF"
                textColor="#FFFFFFFF"/>
      </panel>

    </scrollview>

    <panel id="BottomBar" anchor="bottom-center" widthPercent="1" height="126" background="#1A1A30FF">
      <button id="BackBtn"
              anchor="middle-left"
              x="20"
              width="280"
              height="92"
              text="Back"
              buttonFontSize="44"
              icon="TimeLoop/Icons/ic_back"
              iconSize="36"
              iconAlign="left"
              buttonColor="#5B647FFF"
              textColor="#FFFFFFFF"
              event="creation.back"/>

      <button id="SavePresetBtn"
              anchor="middle-right"
              x="-20"
              width="340"
              height="92"
              text="Save"
              buttonFontSize="40"
              icon="TimeLoop/Icons/ic_timer"
              iconSize="36"
              iconAlign="left"
              buttonColor="#3E4A74FF"
              textColor="#C5CCE4FF"/>
    </panel>

    <!-- Transparent overlay to close color picker when clicking outside -->
    <button id="ColorPickerOverlay" anchor="middle-center" stretch="true" buttonColor="#00000000" textColor="#00000000" active="false"/>

    <panel id="ColorPickerPanel" anchor="bottom-center" widthPercent="1" height="460" background="#0D0F1AFF" active="false">
      <row id="ColorPickerRow1"
           anchor="top-center"
           x="0"
           y="-12"
           widthPercent="0.98"
           height="130"
           spacing="6"
           background="transparent">
        <button id="ColorPicker_Red" flex="1" preferredHeight="120" noLabel="true" buttonColor="#E53935FF"/>
        <button id="ColorPicker_Crimson" flex="1" preferredHeight="120" noLabel="true" buttonColor="#DC143CFF"/>
        <button id="ColorPicker_Rose" flex="1" preferredHeight="120" noLabel="true" buttonColor="#E91E63FF"/>
        <button id="ColorPicker_HotPink" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FF1493FF"/>
        <button id="ColorPicker_Magenta" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FF00FFFF"/>
        <button id="ColorPicker_Coral" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FF7F50FF"/>
      </row>

      <row id="ColorPickerRow2"
           anchor="top-center"
           x="0"
           y="-154"
           widthPercent="0.98"
           height="130"
           spacing="6"
           background="transparent">
        <button id="ColorPicker_Blue" flex="1" preferredHeight="120" noLabel="true" buttonColor="#3B6FF5FF"/>
        <button id="ColorPicker_SkyBlue" flex="1" preferredHeight="120" noLabel="true" buttonColor="#00BCDEFF"/>
        <button id="ColorPicker_Cyan" flex="1" preferredHeight="120" noLabel="true" buttonColor="#00FFFFFF"/>
        <button id="ColorPicker_Purple" flex="1" preferredHeight="120" noLabel="true" buttonColor="#8E24AAFF"/>
        <button id="ColorPicker_Indigo" flex="1" preferredHeight="120" noLabel="true" buttonColor="#4B0082FF"/>
        <button id="ColorPicker_Violet" flex="1" preferredHeight="120" noLabel="true" buttonColor="#9400D3FF"/>
      </row>

      <row id="ColorPickerRow3"
           anchor="top-center"
           x="0"
           y="-296"
           widthPercent="0.98"
           height="130"
           spacing="6"
           background="transparent">
        <button id="ColorPicker_Green" flex="1" preferredHeight="120" noLabel="true" buttonColor="#43A047FF"/>
        <button id="ColorPicker_Mint" flex="1" preferredHeight="120" noLabel="true" buttonColor="#00E676FF"/>
        <button id="ColorPicker_Emerald" flex="1" preferredHeight="120" noLabel="true" buttonColor="#00C853FF"/>
        <button id="ColorPicker_Yellow" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FDD835FF"/>
        <button id="ColorPicker_Gold" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FFD700FF"/>
        <button id="ColorPicker_Orange" flex="1" preferredHeight="120" noLabel="true" buttonColor="#FB8C00FF"/>
      </row>
    </panel>

  </panel>

</ui>
