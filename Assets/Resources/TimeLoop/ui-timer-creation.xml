<?xml version="1.0" encoding="utf-8"?>
<ui>

  <panel id="Root" stretch="true" background="#101321FF">

        <panel id="HeaderBar" anchor="top-center" widthPercent="1" height="170" background="#1A1A30FF">
      <text id="CreationTitle"
            anchor="middle-center"
            value="Create Timer"
            widthPercent="0.95"
            height="120"
            align="middle-center"
              fontSize="64"
            color="#E2B96FFF"/>
    </panel>

    <scrollview id="CreationScroll"
                stretch="true"
          top="178"
          bottom="126"
                left="8"
                right="8"
                spacing="12">

      <panel id="PresetSection"
       height="320"
       preferredHeight="320"
             background="#1D2238FF">
        <text id="PresetSectionTitle"
              anchor="top-left"
              x="16"
              y="-22"
          width="420"
              height="42"
              value="Preset Data"
              fontSize="68"
              align="middle-left"
              color="#F4F6FFFF"/>

        <text id="NameLabel"
              anchor="top-left"
              x="16"
              y="-72"
              width="520"
              height="64"
              value="Timer Name"
              fontSize="44"
              align="middle-left"
              color="#C7D1F7FF"/>

        <inputfield id="PresetNameInput"
              anchor="top-center"
              x="0"
                  y="-196"
              widthPercent="0.95"
                height="96"
                    placeholder="Morning Focus"
              inputType="name"
              maxLength="24"
                    background="#262C45FF"
                    color="#FFFFFFFF"
                fontSize="56"/>
      </panel>

      <panel id="LoopSection"
                height="1430"
                preferredHeight="1430"
             background="#1D2238FF">

        <text id="LoopSectionTitle"
              anchor="top-left"
              x="16"
              y="-22"
              width="420"
              height="42"
              value="Loops"
              fontSize="68"
              align="middle-left"
              color="#F4F6FFFF"/>

        <row id="LoopHeaderRow"
             anchor="top-center"
             x="0"
             y="-76"
             widthPercent="1"
             height="96"
             spacing="8"
             background="transparent">
           <text id="LoopNameLabel" preferredWidth="320" preferredHeight="84" value="Loop 1" fontSize="56" align="middle-left" color="#DEE5FFFF"/>
           <text id="RepeatLabel" preferredWidth="300" preferredHeight="84" value="Repeat" fontSize="48" align="middle-right" color="#8D98C4FF"/>
        </row>

        <row id="LoopRepeatControlsRow"
             anchor="top-center"
             x="0"
             y="-190"
             widthPercent="1"
             height="104"
             spacing="10"
             background="#252C48FF">
          <button id="LoopRepeatMinus" flex="1" preferredHeight="88" text="-" buttonFontSize="64" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
          <inputfield id="LoopRepeatInput" flex="2" preferredHeight="88" value="1" placeholder="1" inputType="integer" maxLength="2" background="#262C45FF" color="#FFFFFFFF" fontSize="56"/>
          <button id="LoopRepeatPlus" flex="1" preferredHeight="88" text="+" buttonFontSize="64" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
        </row>

           <separator id="LoopSeparator" anchor="top-center" x="0" y="-302" widthPercent="1" thickness="2" color="#FFFFFF22"/>

        <text id="EntriesTitle"
              anchor="top-left"
              x="16"
            y="-356"
              width="420"
              height="70"
              value="Entries"
              fontSize="56"
              align="middle-left"
              color="#C7D1F7FF"/>

        <row id="EntryRowHeader"
             anchor="top-center"
             x="0"
             y="-430"
             widthPercent="1"
             height="60"
             spacing="8"
             background="transparent">
           <text id="EntryNameHead" flex="1" preferredHeight="54" value="Name" fontSize="44" align="middle-left" color="#8D98C4FF"/>
        </row>

        <row id="EntryRow1"
             anchor="top-center"
             x="0"
             y="-500"
             widthPercent="1"
             height="110"
             spacing="8"
             background="#252C48FF">
            <inputfield id="Entry1Name" flex="1" preferredHeight="92" value="Warmup" placeholder="Entry name" inputType="name" maxLength="24" background="#262C45FF" color="#FFFFFFFF" fontSize="52"/>
        </row>

        <row id="EntryDurationHeader"
             anchor="top-center"
             x="0"
             y="-622"
             widthPercent="1"
             height="60"
             spacing="8"
             background="transparent">
           <text id="EntryDurationHead" flex="1" preferredHeight="54" value="Duration (MM:SS)" fontSize="44" align="middle-left" color="#8D98C4FF"/>
        </row>

        <row id="EntryDurationRow"
             anchor="top-center"
             x="0"
             y="-692"
             widthPercent="1"
             height="110"
             spacing="8"
             background="#252C48FF">
          <button id="Entry1DurationMinus" flex="1" preferredHeight="92" text="-" buttonFontSize="56" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
           <inputfield id="Entry1Duration" flex="2" preferredHeight="92" value="05:00" placeholder="00:30" inputType="duration" maxLength="5" background="#262C45FF" color="#FFFFFFFF" fontSize="52"/>
          <button id="Entry1DurationPlus" flex="1" preferredHeight="92" text="+" buttonFontSize="56" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
        </row>

        <row id="EntryControlsRow"
             anchor="top-center"
             x="0"
             y="-814"
             widthPercent="1"
             height="110"
             spacing="12"
             background="#252C48FF">
          <button id="Entry1Color" flex="1" preferredHeight="92" text="Blue" buttonFontSize="42" buttonColor="#3B6FF5FF" textColor="#FFFFFFFF"/>
          <button id="Entry1Dup" flex="1" preferredHeight="92" text="Duplicate" buttonFontSize="42" icon="TimeLoop/Icons/ic_duplicate" iconSize="36" iconAlign="left" buttonColor="#38405EFF" textColor="#FFFFFFFF"/>
          <button id="Entry1Delete" flex="1" preferredHeight="92" text="Delete" buttonFontSize="42" icon="TimeLoop/Icons/ic_delete" iconSize="36" iconAlign="left" buttonColor="#7A2A32FF" textColor="#FFFFFFFF"/>
        </row>

        <row id="AddButtonsRow"
             anchor="top-center"
             x="0"
             y="-968"
             widthPercent="1"
             height="110"
             spacing="12"
             background="transparent">
          <button id="AddEntryBtn"
                  flex="1"
                  preferredHeight="96"
                  text="Add Entry"
                  buttonFontSize="42"
                  icon="TimeLoop/Icons/ic_add"
                  iconSize="36"
                  iconAlign="left"
                  buttonColor="#38405EFF"
                  textColor="#FFFFFFFF"/>
          <button id="AddLoopBtn"
                  flex="1"
                  preferredHeight="96"
                  text="Add Loop"
                  buttonFontSize="42"
                  icon="TimeLoop/Icons/ic_add"
                  iconSize="36"
                  iconAlign="left"
                  buttonColor="#38405EFF"
                  textColor="#FFFFFFFF"/>
        </row>

      </panel>

    </scrollview>

    <panel id="BottomBar" anchor="bottom-center" widthPercent="1" height="126" background="#1A1A30FF">
      <button id="BackBtn"
              anchor="middle-left"
              x="20"
              width="280"
              height="92"
              text="Back"
              buttonFontSize="44"
              icon="TimeLoop/Icons/ic_back"
              iconSize="36"
              iconAlign="left"
              buttonColor="#5B647FFF"
              textColor="#FFFFFFFF"
              event="creation.back"/>

      <button id="SavePresetBtn"
              anchor="middle-right"
              x="-20"
              width="340"
              height="92"
              text="Save (Soon)"
              buttonFontSize="40"
              icon="TimeLoop/Icons/ic_timer"
              iconSize="36"
              iconAlign="left"
              buttonColor="#3E4A74FF"
              textColor="#C5CCE4FF"/>
    </panel>

  </panel>

</ui>
