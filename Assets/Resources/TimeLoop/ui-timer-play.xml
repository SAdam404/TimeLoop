<?xml version="1.0" encoding="utf-8"?>
<ui>
  <panel id="Root" stretch="true" background="#0F0F1EFF">

    <panel id="PlayCenterPanel"
           stretch="true"
           top="12"
           bottom="12"
           left="12"
           right="12"
           background="#223255FF">

      <button id="PrevEntryBtn"
              anchor="top-left"
              x="12"
              y="-12"
              width="120"
              height="100"
              noLabel="true"
              buttonColor="#00000000"
              icon="TimeLoop/Icons/GoogleIcons/chevron_left"
              iconSize="72"
              iconColor="#FFFFFFFF"
              textColor="#FFFFFFFF"/>

      <button id="ExitHoldBtn"
              anchor="top-center"
              x="0"
              y="-12"
              width="420"
              height="100"
              text="Hold to exit"
              buttonFontSize="44"
              buttonColor="#00000000"
              textColor="#FFFFFFFF"/>

      <button id="NextEntryBtn"
              anchor="top-right"
              x="-12"
              y="-12"
              width="120"
              height="100"
              noLabel="true"
              buttonColor="#00000000"
              icon="TimeLoop/Icons/GoogleIcons/chevron_right"
              iconSize="72"
              iconColor="#FFFFFFFF"
              textColor="#FFFFFFFF"/>

      <text id="PlayCountdownLabel"
            anchor="middle-center"
            y="-70"
            widthPercent="0.92"
            height="180"
            value="00:00"
            fontSize="148"
            align="middle-center"
            color="#FFFFFFFF"
            active="true"/>

      <text id="PlayRepCountLabel"
            anchor="middle-center"
            y="-70"
            widthPercent="0.92"
            height="180"
            value="0"
            fontSize="148"
            align="middle-center"
            color="#FFFFFFFF"
            active="false"/>

      <text id="PlayEntryNameLabel"
            anchor="middle-center"
            y="54"
            widthPercent="0.92"
            height="120"
            value="Entry"
            fontSize="72"
            align="middle-center"
            color="#F2F4FFFF"/>

      <button id="PauseResumeBtn"
              anchor="bottom-right"
              x="-12"
              y="12"
              width="180"
              height="140"
              noLabel="true"
              buttonColor="#00000000"
              icon="TimeLoop/Icons/GoogleIcons/pause_circle"
              iconSize="108"
              iconColor="#FFFFFFFF"
              textColor="#FFFFFFFF"
              active="true"/>

      <button id="DoneBtn"
              anchor="bottom-right"
              x="-12"
              y="12"
              width="260"
              height="94"
              text="Done"
              buttonFontSize="44"
              buttonColor="#00000000"
              textColor="#FFFFFFFF"
              active="false"/>
    </panel>
  </panel>
</ui>
